<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="14dp"
    android:background="@drawable/widget_bg">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="10dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="☰ TÂCHES"
            android:textColor="#B8935B"
            android:textSize="10sp"
            android:letterSpacing="0.14"
            android:textAllCaps="true"
            android:fontFamily="monospace" />

        <TextView
            android:id="@+id/list_counter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0/0"
            android:textColor="#77828F"
            android:textSize="11sp"
            android:fontFamily="monospace" />
    </LinearLayout>

    <!-- Task 1 -->
    <LinearLayout
        android:id="@+id/list_task_1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:visibility="gone">
        <ImageView
            android:id="@+id/list_check_1"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_check_empty"
            android:layout_marginEnd="10dp"
            android:contentDescription="check" />
        <TextView
            android:id="@+id/list_title_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#ECE5D4"
            android:textSize="13sp"
            android:maxLines="1"
            android:ellipsize="end" />
    </LinearLayout>

    <!-- Task 2 -->
    <LinearLayout
        android:id="@+id/list_task_2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:visibility="gone">
        <ImageView
            android:id="@+id/list_check_2"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_check_empty"
            android:layout_marginEnd="10dp"
            android:contentDescription="check" />
        <TextView
            android:id="@+id/list_title_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#ECE5D4"
            android:textSize="13sp"
            android:maxLines="1"
            android:ellipsize="end" />
    </LinearLayout>

    <!-- Task 3 -->
    <LinearLayout
        android:id="@+id/list_task_3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:visibility="gone">
        <ImageView
            android:id="@+id/list_check_3"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_check_empty"
            android:layout_marginEnd="10dp"
            android:contentDescription="check" />
        <TextView
            android:id="@+id/list_title_3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#ECE5D4"
            android:textSize="13sp"
            android:maxLines="1"
            android:ellipsize="end" />
    </LinearLayout>

    <!-- Task 4 -->
    <LinearLayout
        android:id="@+id/list_task_4"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:visibility="gone">
        <ImageView
            android:id="@+id/list_check_4"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_check_empty"
            android:layout_marginEnd="10dp"
            android:contentDescription="check" />
        <TextView
            android:id="@+id/list_title_4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#ECE5D4"
            android:textSize="13sp"
            android:maxLines="1"
            android:ellipsize="end" />
    </LinearLayout>

    <!-- Task 5 -->
    <LinearLayout
        android:id="@+id/list_task_5"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:visibility="gone">
        <ImageView
            android:id="@+id/list_check_5"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_check_empty"
            android:layout_marginEnd="10dp"
            android:contentDescription="check" />
        <TextView
            android:id="@+id/list_title_5"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#ECE5D4"
            android:textSize="13sp"
            android:maxLines="1"
            android:ellipsize="end" />
    </LinearLayout>

    <!-- Empty state -->
    <TextView
        android:id="@+id/list_empty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text="Aucune tâche"
        android:textColor="#77828F"
        android:textSize="12sp"
        android:gravity="center"
        android:visibility="visible" />
</LinearLayout>
