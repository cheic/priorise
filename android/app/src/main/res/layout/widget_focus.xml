<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@drawable/widget_bg">

    <!-- Header (Top left) -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🎯 FOCUS"
        android:textColor="@color/widget_text_eyebrow"
        android:textSize="10sp"
        android:letterSpacing="0.14"
        android:textAllCaps="true"
        android:fontFamily="monospace"
        android:gravity="start|center_vertical" />

    <!-- Content (when task exists) -->
    <LinearLayout
        android:id="@+id/focus_content"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:visibility="visible">

        <TextView
            android:id="@+id/focus_role"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="STRATÉGIQUE"
            android:textColor="@color/widget_brass_bright"
            android:textSize="9sp"
            android:fontFamily="monospace"
            android:textAllCaps="true"
            android:background="@drawable/tag_bg"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="4dp"
            android:layout_gravity="center_horizontal"
            android:gravity="center" />

        <TextView
            android:id="@+id/focus_title"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:text="Votre priorité"
            android:textColor="@color/widget_text_primary"
            android:textSize="16sp"
            android:maxLines="2"
            android:ellipsize="end"
            android:gravity="start|center_vertical" />
    </LinearLayout>

    <!-- Empty state -->
    <TextView
        android:id="@+id/focus_empty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text="Aucune Grosse Pierre définie.\nOuvrez Priorise pour planifier."
        android:textColor="@color/widget_text_secondary"
        android:textSize="12sp"
        android:gravity="center"
        android:visibility="gone" />
</LinearLayout>
