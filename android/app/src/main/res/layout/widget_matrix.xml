<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:gravity="center"
    android:background="@drawable/widget_bg">

    <!-- Header -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="⊞ MATRICE"
        android:textColor="@color/widget_text_eyebrow"
        android:textSize="10sp"
        android:letterSpacing="0.14"
        android:textAllCaps="true"
        android:fontFamily="monospace"
        android:gravity="center"
        android:layout_marginBottom="8dp" />

    <!-- 2x2 Grid -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Row 1: Q2 + Q1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">

            <!-- Q2: Important + Non Urgent (Grosses Pierres) -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/quadrant_q2_bg"
                android:padding="8dp"
                android:gravity="center"
                android:layout_marginEnd="2dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="STRATÉGIQUE"
                    android:textColor="@color/widget_brass_bright"
                    android:textSize="8sp"
                    android:letterSpacing="0.05"
                    android:fontFamily="monospace" />
                <TextView
                    android:id="@+id/matrix_q2_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/widget_brass_bright"
                    android:textSize="22sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Q1: Important + Urgent -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/quadrant_bg"
                android:padding="8dp"
                android:gravity="center"
                android:layout_marginStart="2dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="URGENT"
                    android:textColor="@color/widget_urgent"
                    android:textSize="8sp"
                    android:letterSpacing="0.05"
                    android:fontFamily="monospace" />
                <TextView
                    android:id="@+id/matrix_q1_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/widget_urgent"
                    android:textSize="22sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- Row 2: Q3 + Q4 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- Q3 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/quadrant_bg"
                android:padding="8dp"
                android:gravity="center"
                android:layout_marginEnd="2dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ILLUSION"
                    android:textColor="@color/widget_dim"
                    android:textSize="8sp"
                    android:letterSpacing="0.05"
                    android:fontFamily="monospace" />
                <TextView
                    android:id="@+id/matrix_q3_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/widget_dim"
                    android:textSize="22sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Q4 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/quadrant_bg"
                android:padding="8dp"
                android:gravity="center"
                android:layout_marginStart="2dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DISTRACTION"
                    android:textColor="@color/widget_dim"
                    android:textSize="8sp"
                    android:letterSpacing="0.05"
                    android:fontFamily="monospace" />
                <TextView
                    android:id="@+id/matrix_q4_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/widget_dim"
                    android:textSize="22sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
